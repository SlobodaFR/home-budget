# Copiez ce fichier en .env (jamais commite) et completez les valeurs.

# Requis - service d'authentification central (auth.sloboda.fr)
AUTH_SERVICE_URL=https://auth.sloboda.fr
AUTH_CLIENT_ID=budget
AUTH_CLIENT_SECRET=change-me

# Requis - secret partage avec auth-service pour le webhook de revocation
# (POST /api/auth/internal/session-revoked, header X-Webhook-Secret)
AUTH_WEBHOOK_SECRET=change-me

# Optionnel - base URL du frontend, utilisee pour le redirect_uri OAuth2 et CORS
FRONTEND_URL=http://localhost:3000

# Optionnel - chemin du fichier SQLite
DATABASE_PATH=

# Optionnel
NODE_ENV=development
PORT=3000

# Optionnel - replication Litestream de la DB SQLite vers MinIO (S3-compatible)
# Si MINIO_BUCKET est defini, le conteneur restaure la DB au demarrage et la
# replique en continu.
MINIO_ENDPOINT=
MINIO_BUCKET=
MINIO_REPLICA_PATH=foyer-budget
MINIO_REGION=us-east-1
MINIO_ACCESS_KEY_ID=
MINIO_SECRET_ACCESS_KEY=
